@model TSManager.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="fw-bold">TS Manager</h1>
        <p class="text-muted mb-0">Overview of upcoming renewals.</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Software (next @Model.Days30 days)</div>
                    <div class="display-6 fw-bold">@Model.SoftwareExpiring30.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Domains (next @Model.Days30 days)</div>
                    <div class="display-6 fw-bold">@Model.DomainsExpiring30.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Software (@Model.Days30–@Model.Days60 days)</div>
                    <div class="display-6 fw-bold">@Model.SoftwareExpiring60.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Domains (@Model.Days30–@Model.Days60 days)</div>
                    <div class="display-6 fw-bold">@Model.DomainsExpiring60.Count</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Software expiring in next @Model.Days30 days</h5>

                    @if (!Model.SoftwareExpiring30.Any())
                    {
                        <div class="text-muted">No software renewals in the next @Model.Days30 days.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Software</th>
                                        <th>Plan</th>
                                        <th>Renewal</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var s in Model.SoftwareExpiring30)
                                {
                                    <tr>
                                        <td>@s.Software</td>
                                        <td>@s.PlanType</td>
                                        <td><span class="badge bg-danger">@s.RenewalDate.ToString("yyyy-MM-dd")</span></td>
                                        <td class="text-end">@s.Amount.ToString("0.00")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <a class="btn btn-outline-primary btn-sm" asp-controller="SoftwareSubscriptions" asp-action="Index">Open Software</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Domains expiring in next @Model.Days30 days</h5>

                    @if (!Model.DomainsExpiring30.Any())
                    {
                        <div class="text-muted">No domain renewals in the next @Model.Days30 days.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Domain</th>
                                        <th>Registrar</th>
                                        <th>Renewal</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var d in Model.DomainsExpiring30)
                                {
                                    <tr>
                                        <td>@d.DomainName</td>
                                        <td>@d.Registrar</td>
                                        <td><span class="badge bg-danger">@d.RenewalDate.ToString("yyyy-MM-dd")</span></td>
                                        <td class="text-end">@d.Amount.ToString("0.00")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <a class="btn btn-outline-primary btn-sm" asp-controller="Domains" asp-action="Index">Open Domains</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Software expiring in @Model.Days30–@Model.Days60 days</h6>

                    @if (!Model.SoftwareExpiring60.Any())
                    {
                        <div class="text-muted">None.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                        @foreach (var s in Model.SoftwareExpiring60)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@s.Software</span>
                                <span class="badge bg-warning text-dark">@s.RenewalDate.ToString("yyyy-MM-dd")</span>
                            </li>
                        }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Domains expiring in @Model.Days30–@Model.Days60 days</h6>

                    @if (!Model.DomainsExpiring60.Any())
                    {
                        <div class="text-muted">None.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                        @foreach (var d in Model.DomainsExpiring60)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@d.DomainName</span>
                                <span class="badge bg-warning text-dark">@d.RenewalDate.ToString("yyyy-MM-dd")</span>
                            </li>
                        }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
