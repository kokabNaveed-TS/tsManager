@model TSManager.Models.EmailUser

<div class="container py-4">
    <h2 class="fw-bold mb-3">Add Email User</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input class="form-control" asp-for="FirstName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input class="form-control" asp-for="LastName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input class="form-control" asp-for="EmailAddress" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Company</label>
                        <input class="form-control" asp-for="Company" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Storage (GB)</label>
                        <input class="form-control" asp-for="StorageGb" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Password</label>
                        <input class="form-control" asp-for="Password" type="password" />
                    </div>
                </div>

                <div class="mt-4">
                    <button class="btn btn-primary">Save</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
