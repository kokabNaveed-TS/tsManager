@model TSManager.Models.DomainDetail

<div class="container py-4">
    <h2 class="fw-bold mb-3">Edit Domain</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Domain Name</label>
                        <input class="form-control" asp-for="DomainName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Registrar</label>
                        <input class="form-control" asp-for="Registrar" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Registered Date</label>
                        <input class="form-control" asp-for="RegisteredDate" type="date" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Renewal Date</label>
                        <input class="form-control" asp-for="RenewalDate" type="date" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Amount</label>
                        <input class="form-control" asp-for="Amount" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Nameserver 1</label>
                        <input class="form-control" asp-for="NameServer1" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Nameserver 2</label>
                        <input class="form-control" asp-for="NameServer2" />
                    </div>

                    <div class="col-md-12 form-check mt-3">
                        <input class="form-check-input" asp-for="AutoRenew" />
                        <label class="form-check-label">Auto Renew</label>
                    </div>
                </div>

                <div class="mt-4">
                    <button class="btn btn-primary">Save Changes</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
