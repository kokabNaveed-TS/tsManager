@model TSManager.Models.SoftwareSubscription
@{
    ViewData["Title"] = "Delete Software Subscription";
}

<div class="container py-4">
    <h2 class="fw-bold mb-3">Delete Software Subscription</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete <strong>@Model.Software</strong>?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Category</dt>
                <dd class="col-sm-9">@Model.Category</dd>

                <dt class="col-sm-3">Plan</dt>
                <dd class="col-sm-9">@Model.PlanType</dd>

                <dt class="col-sm-3">Amount</dt>
                <dd class="col-sm-9">@Model.Amount</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.SubscribedEmail</dd>

                <dt class="col-sm-3">Renewal</dt>
                <dd class="col-sm-9">@Model.RenewalDate.ToString("yyyy-MM-dd")</dd>
            </dl>

            <form asp-action="Delete" method="post" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <button class="btn btn-danger" type="submit">Yes, Delete</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </form>
        </div>
    </div>
</div>
