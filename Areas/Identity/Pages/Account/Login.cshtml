@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="card auth-card">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3 mb-3">
            <img src="~/images/SIGN.PNG" class="auth-logo" alt="TS Manager" />
            <div>
                <div class="h4 fw-bold mb-0 text-dark">TS Manager</div>
                <div class="text-muted">Sign in to continue</div>
            </div>
        </div>

        <form id="account" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email"
                       type="email"
                       class="form-control form-control-lg"
                       placeholder="name@company.com"
                       autocomplete="username"
                       autofocus />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password"
                       type="password"
                       class="form-control form-control-lg"
                       placeholder="Enter your password"
                       autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 auth-actions">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                </div>
                <div class="auth-forgot">
                    <a asp-page="./ForgotPassword">Forgot password?</a>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                Log in
            </button>
        </form>

        <div class="text-center text-muted mt-3 small">
            © 2026 TS Manager
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
